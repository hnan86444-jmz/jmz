# ============================================================
# LLM (Large Language Model) Configuration
# ============================================================
# OpenAI API Key (Required)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI API Base URL (Optional, for custom/third-party endpoints)
# 如果使用官方OpenAI，保持默认即可；如果使用兼容API（如DeepSeek、硅基流动等），请修改
# 注意：这是基础URL，不是完整的端点路径
OPENAI_BASE_URL=our-openai-base-url-here

# LLM Model Name (Optional, default: gpt-3.5-turbo)
# 支持的模型示例: gpt-3.5-turbo, gpt-4, gpt-4o, deepseek-chat, etc.
OPENAI_MODEL=your-openai-model-here

# ============================================================
# MCP Server URLs (Optional, defaults are provided)
# ============================================================
# 新闻服务器地址
MCP_NEWS_SERVER_URL=http://localhost:8001/mcp

# 储量数据服务器地址
MCP_MINING_SERVER_URL=http://localhost:8002/mcp

# 价格服务器地址
MCP_PRICE_SERVER_URL=http://localhost:8003/mcp

# ============================================================
# External Data API Keys (Optional)
# ============================================================
# Metals API Configuration (Optional - for real-time price data)
METALS_API_KEY=your-metals-api-key-here

# Commodities API Configuration (Optional - for real-time price data)
COMMODITIES_API_KEY=your-commodities-api-key-here

# News API Configuration (Optional - for additional news sources)
NEWS_API_KEY=your-news-api-key-here
